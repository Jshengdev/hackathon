# Empathy Layer Engine env vars — copy to caltech/engine/.env and fill in.
#
# Three live providers for the new Empathy Engine. The older
# junsoo/report_card/ pipeline is K2-only; this engine adds OpenRouter
# (Stage 1 vision) + Anthropic (Stage 2 synthesis) on top.

# ── Cerebras K2 (swarm specialist calls + iterative loop orchestration) ─────
# Same key + endpoint as the live B2C swarm and junsoo/report_card/.
K2_API_KEY=your_cerebras_key_here
K2_BASE_URL=https://api.cerebras.ai/v1
K2_MODEL=k2-think-v2
K2_TIMEOUT=45.0

# ── OpenRouter (Stage 1 vision classification — Qwen3-VL) ───────────────────
# Required for the live vision call. MOCK_VISION=1 bypasses this.
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Qwen3-VL model id. Note: Johnny verbatim said "Qwen 3.5" but that
# model name does not exist; Qwen3-VL is the correct name.
QWEN_MODEL=qwen/qwen3-vl-235b-a22b-instruct

# ── Anthropic (Stage 2 empathy synthesis — Claude Opus 4.7) ─────────────────
# Required for the live synthesis call. MOCK_OPUS=1 bypasses this.
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

# ── Mock toggles (set to 1 to bypass live calls in offline tests) ───────────
# Useful for CI / no-network dev. Set together for full-pipeline mock.
# MOCK_FORWARD=1
# MOCK_VISION=1
# MOCK_OPUS=1
# MOCK_K2=1
