# Junsoo lane env vars — copy to junsoo/.env and fill in.
#
# The live B2C swarm (_bmad/brain-swarm/backend/.env) uses the SAME variable
# names, so you can symlink instead:
#     ln -s ../_bmad/brain-swarm/backend/.env junsoo/.env

# ── K2 (Cerebras reasoning model — for the 8 specialist calls) ─────────────
# Required. Cerebras-issued key.
K2_API_KEY=your_cerebras_key_here

# Default Cerebras endpoint. NOTE: if your key is IFM-prefixed, you MUST
# point at the IFM host instead — api.cerebras.ai will return 401 for those
# keys. Check the .env in _bmad/brain-swarm/backend/ for the team's working
# value if unsure.
K2_BASE_URL=https://api.cerebras.ai/v1

# K2 Think v2 — reasoning model used for specialist observation calls.
K2_MODEL=k2-think-v2

# Per-call timeout in seconds. K2 Think can be slow when it reasons.
K2_TIMEOUT=45.0

# ── Instruct model (for the JSON synthesis step) ───────────────────────────
# Default 'cerebras' uses the same K2_API_KEY + K2_BASE_URL but a different
# (instruct-tuned) model. Switch to 'anthropic' if Cerebras Llama is
# unavailable or for higher-quality JSON output.
INSTRUCT_PROVIDER=cerebras

# Default Cerebras instruct model. Override if your account has a different
# Llama-3.3 or Llama-3.1 SKU enabled.
INSTRUCT_MODEL=llama-3.3-70b

# Synthesis-call timeout. Longer than K2_TIMEOUT because the synthesis prompt
# is bigger (8 specialist observations + rubric).
INSTRUCT_TIMEOUT=60.0

# ── Anthropic fallback (only required if INSTRUCT_PROVIDER=anthropic) ──────
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Claude Haiku 4.5 — fast, cheap, excellent at structured JSON.
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
