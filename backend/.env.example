# Cerebras K2 (swarm specialists, moderator synthesis, evaluators).
# Get a key from https://cloud.cerebras.ai/.
K2_API_KEY=your_cerebras_k2_key_here
K2_BASE_URL=https://api.cerebras.ai/v1
K2_MODEL=k2-think-v2
# K2 Think generates ~50 tok/s and the moderator call budgets up to 4800 tokens.
# Keep this >= 120s; lower values cause httpx ReadTimeouts in empathy synthesis.
K2_TIMEOUT=180.0

DATA_DIR=./data

# Vision LLM for /demo/vision-report (Stage 1A).
# Code is hardcoded to OpenRouter (Qwen3-VL by default).
# Get a key from https://openrouter.ai/.
VISION_API_KEY=your_openrouter_key_here
VISION_MODEL=qwen/qwen3-vl-235b-a22b-instruct
VISION_TIMEOUT=60.0

# Anthropic Opus 4.7 for Stage 4 empathy synthesis (final document polish).
# When unset or OPUS_POLISH=0, Stage 4 is skipped and synthesis_document is null.
ANTHROPIC_API_KEY=your_anthropic_key_here
ANTHROPIC_MODEL=claude-opus-4-7
OPUS_POLISH=1
