K2_API_KEY=your_cerebras_k2_key_here
K2_BASE_URL=https://api.cerebras.ai/v1
K2_MODEL=k2-think-v2
DATA_DIR=./data

# Vision LLM for /demo/vision-report and /demo/comparison.
# Provider: anthropic | openai | gemini
VISION_API_KEY=your_anthropic_or_gemini_key_here
VISION_PROVIDER=anthropic
VISION_MODEL=claude-sonnet-4-5
VISION_TIMEOUT=60.0
