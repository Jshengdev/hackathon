# GPU-box env — only needed on the Vultr instance running TRIBE V2.
# Source this in the venv shell that runs `bash infer_pipeline.sh`.
#
# HF auth is normally handled via `huggingface-cli login` (writes
# ~/.huggingface/token); HF_TOKEN here is a fallback for headless runs.

HF_TOKEN=

# Where TRIBE V2 weights cache. Need ~15 GB headroom.
TRIBE_CACHE=./cache

# TRIBE model id on Hugging Face — leave default unless you forked.
TRIBE_MODEL_ID=facebook/tribev2

# Atlas for aggregate.py (yeo7 is the default in infer_pipeline.sh).
ATLAS=yeo7
