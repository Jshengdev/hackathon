# OS noise
.DS_Store
Thumbs.db

# Git worktrees (isolated parallel workspaces)
.worktrees/

# Node
node_modules/
*.log
npm-debug.log*

# Env
.env
.env.local
.env.*.local

# Editor scratch
.vscode/
.idea/
*.swp

# Local-only Claude state (don't sync chat history across machines)
.claude/projects/

# Nested project workspace — tracked in its own repo (Jshengdev/feesh)
feesh/

# Cloned third-party hackathon-winning repos (research material, not ours)
research/sponsors/*/clones/*
!research/sponsors/*/clones/.gitkeep
research/sources/repos/*
!research/sources/repos/.gitkeep

# Locally-installed Claude Code skill plugins (third-party, large, reproducible via clone)
.claude/skills/

# junsoo/ slice — local Python build artifacts and vendored third-party clone
junsoo/__pycache__/
junsoo/cache/
junsoo/tribev2/
junsoo/out/

# Pre-rendered TRIBE outputs — keep activity.json (Contract A), drop big binaries
junsoo/prerendered/**/*.npz
junsoo/prerendered/**/*.pkl
junsoo/prerendered/**/*.meta.json

# brain-swarm slice — local Python build artifacts, venv, runtime data, model cache
backend/__pycache__/
backend/services/__pycache__/
backend/.venv/
backend/data/
backend/cache/
frontend/node_modules/
frontend/dist/

# Per-clip K2/Opus baked outputs — regenerated by warmup_clip(); never commit.
# Inputs (activity.json, scenario.json, *.mp4) stay tracked.
backend/prerendered/*/vision_report.json
backend/prerendered/*/swarm_readings.json
backend/prerendered/*/k2_region_cache.json
backend/prerendered/*/empathy.json
backend/prerendered/*/iterative_trajectory.json
backend/prerendered/*/falsification.json
backend/prerendered/*/comparison.json

junsoo/report_card/__pycache__/

caltech/engine/__pycache__/
junsoo/brain/__pycache__/

# Worktrees (audit-time scratch; reports preserved in caltech/audits/)
worktrees/
archive/worktrees/

# Hand-authored synthesis docs (not real Opus output) — kept local for
# demo display, never committed. The 5 other clips' synthesis.json files
# are real Opus bakes and remain tracked.
backend/prerendered/30s_instagram/synthesis.json
backend/prerendered/30s_cop/synthesis.json
backend/prerendered/30s_professor/synthesis.json
